# CDN for vehicle photos, resolved dynamically per-vehicle by VIN.
# See src/server/services/cdn-image.service.ts for how these are used.
# The listing endpoint is CDN_BASE_URL + CDN_VEHICLE_LIST_PATH + "/" + CDN_LIST_TOKEN + CDN_VEHICLE_PUBLIC_PATH + "/{VIN}/"
# and returns a JSON directory listing. Public image URLs are
# CDN_BASE_URL + CDN_VEHICLE_PUBLIC_PATH + "/{VIN}/{filename}" (no token needed).
# CDN_LIST_TOKEN is a real secret — server-side only, never exposed to the browser.
CDN_BASE_URL="https://cdn.kinsen.gr"
CDN_LIST_TOKEN="replace-me"
CDN_VEHICLE_LIST_PATH="/_list"
CDN_VEHICLE_PUBLIC_PATH="/usedcars"
CDN_FETCH_TIMEOUT_MS="2500"
CDN_CACHE_TTL_SECONDS="300"
CDN_LIST_CONCURRENCY="6"
